# Copy to deploy/acr.env and fill in. deploy/acr.env is gitignored.
# 推荐：不在本机跑全套服务，仅配置本文件后用 build-acr.sh 构建并推送 ACR，在云上部署。
#
# Full image: ${ACR_REGISTRY}/${FRONTEND_IMAGE_NAME}:${IMAGE_TAG}
# Example: registry.cn-hangzhou.aliyuncs.com/acme-corp/monitor-admin-frontend:latest

# 阿里云 ACR：registry.<region>.aliyuncs.com/<命名空间>
ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com/your-namespace

FRONTEND_IMAGE_NAME=monitor-admin-frontend
BACKEND_IMAGE_NAME=monitor-admin-backend
IMAGE_TAG=latest

# Next.js 构建期注入：管理后台调用的后端 API 根地址（无末尾斜杠）
NEXT_PUBLIC_API_BASE_URL=https://your-monitor-api.example.com

# 可选：设置后脚本会在推送前执行 docker login（勿提交真实密码）
# ACR_USERNAME=阿里云账号或 RAM 用户名
# ACR_PASSWORD=密码或控制台「访问凭证」临时密码
