# 复制为本目录下的 .env 后填写（勿提交 .env）。
# docker compose 会读取本文件同级 .env 做变量替换，并作为 backend 的 env_file。

# ─── 镜像（与 deploy/acr.env / build-acr.sh 推送结果一致）───
ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com/your-namespace
FRONTEND_IMAGE_NAME=monitor-admin-frontend
BACKEND_IMAGE_NAME=monitor-admin-backend
IMAGE_TAG=latest

# 宿主机映射端口（容器内固定 3011 / 4010）
FRONTEND_HOST_PORT=3011
BACKEND_HOST_PORT=4010

# ─── 数据库 ───────────────────────────────────────────────
# 方案 A：使用外部数据库（阿里云 RDS / 自建独立 Postgres）
#   直接填写 DATABASE_URL，启动命令：docker compose up -d
#
# 方案 B：同机自带 Postgres（compose 内的 postgres 服务，profile=db）
#   - 使用下方 POSTGRES_* 变量
#   - DATABASE_URL 主机名固定为服务名 `postgres`
#   - 启动命令：docker compose --profile db up -d
POSTGRES_USER=postgres
POSTGRES_PASSWORD=请替换为强密码
POSTGRES_DB=monitor

# 外部库示例：postgresql://user:password@your-rds-host:5432/monitor?schema=public
# 同机 postgres 示例（与上面 POSTGRES_* 保持一致）：
DATABASE_URL=postgresql://postgres:请替换为强密码@postgres:5432/monitor?schema=public

# ─── 后端运行时 ───────────────────────────────────────────
JWT_SECRET=请替换为足够长的随机串

# 浏览器访问管理后台的完整来源（含协议、不带末尾斜杠），用于 CORS。
# 必须与浏览器地址栏里的 origin 完全一致（协议 + 主机 + 端口都要一样）。
ADMIN_ORIGIN=https://watch.aivelo.net
FRONTEND_URL=https://watch.aivelo.net
# 多个前端域名时用 CORS_ORIGINS 追加（英文逗号分隔，会与上面两个合并去重）
# CORS_ORIGINS=https://watch.aivelo.net,https://other.example.com

# 生产可关闭 Swagger
# API_DOCS_ENABLED=false

# Gumroad → AI News（chrome-ainews）：Ping 中继 Supabase Edge + 本平台建用户/订单
# GUMROAD_PRODUCT_ID_PRO=industry-ai-news-pro
# GUMROAD_PRODUCT_ID_UNLIMITED=industry-ai-news-unlimited
# GUMROAD_AINEWS_APP_SLUG=chrome-ainews
# SUPABASE_GUMROAD_WEBHOOK_URL=https://<project-ref>.supabase.co/functions/v1/gumroad-webhook
# SUPABASE_ANON_KEY=
# GUMROAD_WEBHOOK_SECRET=

