# 复制为 .env 后填写

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/monitor?schema=public"
JWT_SECRET="change-me-in-production"
PORT=4000
FRONTEND_URL="http://localhost:3002"

# OpenAPI / Swagger UI：`http://localhost:${PORT}/api/docs`；生产若不想暴露可设为 false
# API_DOCS_ENABLED=true

# 终端用户 Google 登录：校验前端传来的 id_token（audience）
# 须与营销站 web/.env 中的 GOOGLE_CLIENT_ID / NEXT_PUBLIC_GOOGLE_CLIENT_ID 为同一「Web 应用」客户端 ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
