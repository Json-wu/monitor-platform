# 复制为 .env 后填写

# 密码含 @ # 等特殊字符须 URL 编码（@ → %40），否则连接串会被截断
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/monitor?schema=public"
JWT_SECRET="change-me-in-production"
PORT=4000
FRONTEND_URL="http://localhost:3002"

# OpenAPI / Swagger UI：`http://localhost:${PORT}/api/docs`；生产若不想暴露可设为 false
# API_DOCS_ENABLED=true

# 上色接口 prompt 安全审核（DeepSeek Chat Completions）
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 终端用户 Google 登录：校验前端传来的 id_token（audience）
# 须与营销站 web/.env 中的 GOOGLE_CLIENT_ID / NEXT_PUBLIC_GOOGLE_CLIENT_ID 为同一「Web 应用」客户端 ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Gumroad → AI News（chrome-ainews）：Ping 中继 Supabase Edge + 本平台建用户/订单
# GUMROAD_PRODUCT_ID_PRO=industry-ai-news-pro
# GUMROAD_PRODUCT_ID_UNLIMITED=industry-ai-news-unlimited
# GUMROAD_AINEWS_APP_SLUG=chrome-ainews
# SUPABASE_GUMROAD_WEBHOOK_URL=https://<project-ref>.supabase.co/functions/v1/gumroad-webhook
# SUPABASE_ANON_KEY=
# GUMROAD_WEBHOOK_SECRET=
