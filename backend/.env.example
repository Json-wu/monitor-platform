# 复制为 .env 后填写。行首 # 为注释；未列出的变量见各模块源码。

# ── 基础 ────────────────────────────────────────────────

# PostgreSQL 连接串（Prisma 与 Nest 共用）。
# 密码含 @ # 等特殊字符须 URL 编码（@ → %40），否则连接串会被截断。
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/monitor?schema=public"

# Admin 后台 JWT 签名密钥；生产环境务必改为随机长字符串。
JWT_SECRET="change-me-in-production"

# 终端用户（插件 Google 登录）JWT 签名密钥；未设置时回退为 JWT_SECRET。
# END_USER_JWT_SECRET=

# HTTP 服务监听端口，默认 4000。
PORT=4000

# 管理后台前端根 URL，用于 CORS 白名单（可与 ADMIN_ORIGIN、CORS_ORIGINS 并用）。
FRONTEND_URL="http://localhost:3002"

# 额外 CORS 来源，逗号分隔（如 https://admin.example.com）。
# CORS_ORIGINS=

# 管理后台单独域名（若与 FRONTEND_URL 不同）。
# ADMIN_ORIGIN=

# 是否启用 OpenAPI / Swagger UI（http://localhost:${PORT}/api/docs）。
# 生产环境若不想暴露文档，设为 false。
# API_DOCS_ENABLED=true

# 对外可访问的 API 根 URL（无尾斜杠）；邮件简报退订链接等会用到。
# 未设置时 Ainews 模块回退为 AINEWS_PUBLIC_API_URL 或 http://localhost:4000。
# API_EXTERNAL_URL=

# ── DeepSeek（LLM）──────────────────────────────────────

# DeepSeek API Key；Industry AI News 的 RSS 摘要补全、按需摘要、邮件简报均依赖此项。
# DEEPSEEK_API_KEY=

# DeepSeek Chat Completions 接口根 URL，默认 https://api.deepseek.com。
# DEEPSEEK_API_BASE=https://api.deepseek.com

# 使用的模型名称，默认 deepseek-chat。
# DEEPSEEK_MODEL=deepseek-chat

# ── 终端用户 Google 登录 ────────────────────────────────

# 校验插件 / 前端传来的 Google id_token 的 audience（OAuth Web 客户端 ID）。
# 须与 chrome-ainews 应用配置及插件 PLASMO_PUBLIC_GOOGLE_CLIENT_ID 为同一客户端。
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Gumroad → Industry AI News 订阅 ─────────────────────

# Gumroad 产品 permalink（Pro 档）；用于 Webhook 解析订阅档位。
# GUMROAD_PRODUCT_ID_PRO=industry-ai-news-pro

# Gumroad 产品 permalink（Unlimited 档）。
# GUMROAD_PRODUCT_ID_UNLIMITED=industry-ai-news-unlimited

# Monitor 中 chrome-ainews 应用的 slug，Gumroad relay 路由用，默认 chrome-ainews。
# GUMROAD_AINEWS_APP_SLUG=chrome-ainews

# Gumroad Ping/Webhook 请求校验密钥（与 Gumroad 后台配置一致）。
# GUMROAD_WEBHOOK_SECRET=

# ── Industry AI News 定时任务（AinewsSchedulerService）──

# 设为 1 启用 RSS 抓取与文章入库；间隔由 AINEWS_INGEST_INTERVAL_MINUTES 控制。
# AINEWS_INGEST_ENABLED=1

# RSS 入库任务间隔（分钟），默认 5；≥60 且为 60 的倍数时按小时调度。
# AINEWS_INGEST_INTERVAL_MINUTES=5

# 设为 1 启用定时批量补全缺失的多语言摘要（原 ingest-article-summaries）。
# AINEWS_INGEST_SUMMARIZE_ENABLED=1

# 摘要批量补全任务间隔（分钟），默认 15。
# AINEWS_INGEST_SUMMARIZE_INTERVAL_MINUTES=15

# 设为 1 启用每日邮件简报（每小时检查用户本地 22:00 发送窗口）。
# AINEWS_EMAIL_DIGEST_ENABLED=1

# 设为 1 启用过期文章清理（每天 UTC 03:15）。
# AINEWS_CLEANUP_ENABLED=1

# 设为 1 关闭上述全部 Ainews 定时任务（含动态间隔与固定 cron）。
# DISABLE_AINEWS_SCHEDULER=1

# 文章保留天数；超过此天数的文章会被 cleanup 任务删除，默认 10。
# NEWS_RETENTION_DAYS=10

# 单次 RSS 入库最多抓取并补全头图的文章数，0 表示不抓取，默认 40。
# INGEST_ARTICLE_IMAGE_MAX=40

# RSS 入库完成后即时摘要的最大文章数（仅新入库条目），0 表示关闭，默认 8。
# 即时摘要语言：始终生成 zh、en 标题+正文；若有用户使用 ja/ko/fr 等界面语言则额外生成对应语言。
# INGEST_QUICK_SUMMARIZE_LIMIT=8

# 批量摘要任务的分布式锁 TTL（秒），防止多实例并发跑同一任务，默认 900。
# SUMMARIZE_JOB_LOCK_TTL_SECONDS=900

# 批量摘要扫描的时间窗口（天）：只处理近 N 天内入库/发布的文章，默认 14。
# SUMMARIZE_LOOKBACK_DAYS=14

# 单次批量任务最多扫描并识别为「缺摘要」的文章数，默认 120。
# SUMMARIZE_SCAN_LIMIT=120

# 单次批量任务最多调用 LLM 处理的文章数，默认 40。
# SUMMARIZE_ITEMS_PER_RUN=40

# 批量摘要时每批送入 LLM 的文章数；未设置时用 INGEST_LLM_BATCH_SIZE，再默认 5。
# SUMMARIZE_LLM_BATCH_SIZE=5
# INGEST_LLM_BATCH_SIZE=5

# 抓取 RSS / 文章页时使用的 User-Agent。
# RSS_FETCH_USER_AGENT=IndustryAINews-RSS/1.0 (+ingest)

# ── 按需摘要 API（/api/public/ainews/summarize）────────

# 摘要缓存有效时长（小时），过期后重新调用 LLM，默认 168（7 天）。
# SUMMARY_CACHE_TTL_HOURS=168

# 每用户每日 LLM 摘要调用上限（按需摘要），默认 120。
# SUMMARY_DAILY_LLM_ITEMS_PER_USER=120

# ── 邮件简报（需 AINEWS_EMAIL_DIGEST_ENABLED=1）──────────

# Resend 发信 API Key。
# RESEND_API_KEY=

# 发件人地址，格式可为「名称 <email@domain>」。
# EMAIL_FROM=Aivelo <digest@yourdomain.com>

# 邮件退订链接 HMAC 签名密钥；须与 GET /api/public/ainews/email-unsubscribe 一致。
# EMAIL_UNSUBSCRIBE_SECRET=

# 插件/API 对外根 URL（无尾斜杠），用于简报中的退订与下载链接；默认同 API_EXTERNAL_URL。
# AINEWS_PUBLIC_API_URL=http://localhost:4000
